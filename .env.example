# Cadena de conexión a Postgres (Neon).
#
# - Con "Vercel Postgres (Neon)": Vercel inyecta POSTGRES_URL automáticamente en
#   el despliegue. Para desarrollo local, copia ese valor aquí.
# - Con la integración nativa de Neon: usa DATABASE_URL.
#
# La app y el script de migración aceptan cualquiera de las dos variables.
# Copia este archivo como .env.local y pega tu cadena real (NO la subas a git).

DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST/DBNAME?sslmode=require"
# POSTGRES_URL="postgresql://USUARIO:PASSWORD@HOST/DBNAME?sslmode=require"
